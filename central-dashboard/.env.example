# ═══════════════════════════════════════════════════════════════════
#  Homelab Dashboard — Environment Configuratie
# ═══════════════════════════════════════════════════════════════════
#  Kopieer dit bestand naar .env en vul de juiste waarden in.
#  .env staat in .gitignore — komt NOOIT in git!
# ═══════════════════════════════════════════════════════════════════

# ─── Server ────────────────────────────────────────────────────────
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000

# ─── Security ──────────────────────────────────────────────────────
# Genereer een sterke key met: openssl rand -hex 32
DASHBOARD_API_KEY=vervang-dit-door-een-sterke-key

# ─── Agents (servers) ──────────────────────────────────────────────
# URL + API-key voor elke server-agent
AGENT_UMBRELOS_URL=http://192.168.1.217:9100
AGENT_UMBRELOS_KEY=vervang-dit-door-agent-key

AGENT_UBUNTU_URL=http://192.168.1.3:9100
AGENT_UBUNTU_KEY=vervang-dit-door-agent-key

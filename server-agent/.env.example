# ═══════════════════════════════════════════════════════════════════
#  Homelab Server Agent — Environment Configuratie
# ═══════════════════════════════════════════════════════════════════
#  Kopieer dit bestand naar .env en vul de juiste waarden in.
#  .env staat in .gitignore — komt NOOIT in git!
# ═══════════════════════════════════════════════════════════════════

# ─── Security ──────────────────────────────────────────────────────
# Genereer een sterke key met: openssl rand -hex 32
# Moet minstens 16 karakters lang zijn voor veiligheid.
# Voorbeeld (NIET GEBRUIKEN IN PRODUCTIE):
#   AGENT_API_KEY=a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6
AGENT_API_KEY=vervang-dit-door-een-sterke-key

# ─── Server ────────────────────────────────────────────────────────
AGENT_HOST=0.0.0.0
AGENT_PORT=9100
